# Manoel Island Sandbox — copy to `.env` and fill in values

VITE_ADMIN_PASSWORD=manoel-admin

# Supabase REST API (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Supabase anon *public* key (Project Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=
